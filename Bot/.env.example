# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
# Comma-separated list of Telegram User IDs allowed to use the bot. Leave empty to allow everyone.
ALLOWED_USER_IDS=

# Database & Queue Configuration
# For local development outside docker, you can use: postgresql://postgres:postgres@localhost:5432/transcriber
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/transcriber
# For local development outside docker, you can use: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# Whisper Configuration
# Options: tiny, base, small, medium, large-v3, turbo
WHISPER_MODEL=turbo
# Options: cpu, cuda
WHISPER_DEVICE=cpu
# Options: int8, float16, float32
WHISPER_COMPUTE_TYPE=int8
# Options: auto, uz, ru, en
LANGUAGE=uz

# Diarization Configuration
# Toggle diarization (true/false)
ENABLE_DIARIZATION=true
# Hugging Face auth token (required for pyannote speaker diarization)
PYANNOTE_AUTH_TOKEN=
MIN_SPEAKERS=
MAX_SPEAKERS=

# Translation Configuration
# Toggle translation (true/false)
ENABLE_TRANSLATION=false
# Options: gemini, openai
TRANSLATION_PROVIDER=gemini
# Target languages: Uzbek, Russian, English
TRANSLATION_TARGET_LANGUAGE=English

# Summarization Configuration
# Toggle summary generation (true/false)
ENABLE_SUMMARY=false
# Options: gemini, openai
LLM_PROVIDER=gemini
# API Key for Gemini or OpenAI
LLM_API_KEY=

# File Storage & Cleanup Policy
# Max allowed file size for downloads in MB
MAX_FILE_SIZE_MB=2048
# For chunking long files (minutes). If 0, chunking is disabled.
CHUNK_LENGTH_MINUTES=10
# Cleanup uploaded/processed/exported files older than X days
CLEANUP_AFTER_DAYS=7
